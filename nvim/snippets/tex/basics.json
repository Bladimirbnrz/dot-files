{
    "usepackage": {
        "prefix": ["\\usepackage"],
        "body": ["\\usepackage{$1}"],
        "description": "Add an usepackage"
    },
    "equation": {
        "prefix": ["equation"],
        "body": [
            "\\begin{equation}",
            "\t$0",
            "\\end{equation}"
        ],
        "description": "Equation"
    },
    "equation*": {
        "prefix": ["equation*"],
        "body": [
            "\\begin{equation*}",
            "\t$0",
            "\\end{equation*}"
        ],
        "description": "Equation*"
    },
    "Align(ed)": {
        "prefix": ["align"],
        "body": ["\\begin{align}", "\t$0", "\\end{align}"],
        "description": "Align(ed)"
    },
    "Align*(ed)": {
        "prefix": ["align*"],
        "body": ["\\begin{align*}", "\t$0", "\\end{align*}"],
        "description": "Align*(ed)"
    }
}
